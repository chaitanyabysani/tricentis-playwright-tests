{
  "compilerOptions": {
    "target": "ES2020",
    "module": "node16",
    "lib": ["ES2020", "DOM"],
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "node16",
    "outDir": "./dist",
    "rootDir": "./"
  },
  "include": ["tests/**/*.ts", "pageobjects/**/*.ts", "utils/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
